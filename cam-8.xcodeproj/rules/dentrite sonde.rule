CAM-A
N/MARG
&/CENTERS
: RAND &CENTER' ;
: WALL CENTER' CW' OPP' CCW' OR OR OR ;
: DENDRITE
  WALL IF 0 ELSE RAND { CW CCW } THEN >PLN0
  WALL IF CENTER' CENTER OR ELSE CENTER' THEN >PLN1 ;
MAKE-TABLE DENDRITE

CAM-B
N/MARG-HV
: STIR-SAMPLE-DELAY
  CENTER CW XOR
  CCW OPP AND
  XOR
  CENTER' CCW' AND
  CW' OPP' XOR
  XOR
  XOR
  >PLN2
  CENTER >PLN3 ;
MAKE-TABLE STIR-SAMPLE-DELAY